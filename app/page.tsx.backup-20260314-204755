                    <HoloLine width="w-6" className="mb-4" />
                    <p style={{ fontSize: '14px', lineHeight: 1.75, color: inkMuted, fontStyle: 'italic', marginBottom: '14px' }}>&ldquo;{t.quote}&rdquo;</p>
                    <p style={{ fontSize: '13px', fontWeight: 600, color: ink }}>{t.name}</p>
                    <p style={{ fontSize: '12px', color: inkFaint, marginTop: '2px' }}>{t.role}</p>
                  </div>
                ))}
              </div>
            </div>
          </FadeUp>
        </div>
      </section>

      <SectionFade from={lightBg} to={darkBg} />

      {/* ── Who this is for ── */}
      <section style={{ background: 'linear-gradient(160deg, #080D18 0%, #0D1525 100%)', padding: 'clamp(48px, 8vw, 100px) clamp(24px, 6vw, 80px)' }}>
        <div style={{ maxWidth: '860px', margin: '0 auto' }}>
          <FadeUp>
            <HoloLine width="w-8" className="mb-5" />
            <h2 style={{ fontFamily: 'var(--font-barlow)', fontSize: 'clamp(26px, 3.5vw, 40px)', fontWeight: 800, color: '#F5F3EF', lineHeight: 1.2, marginBottom: '40px', letterSpacing: '-0.01em' }}>
              Who this is for
            </h2>
          </FadeUp>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: '16px' }}>
            {[
              { label: 'In-house legal teams', text: 'Legal departments in medium and large organizations looking to introduce AI into real legal workflows.' },
              { label: 'Compliance teams', text: 'Organizations that need AI use to be compliant with GDPR, EU AI Act, and internal policies.' },
              { label: 'General Counsel and CLOs', text: 'Legal leaders who need a clear, honest picture of what AI adoption actually takes. Not a vendor pitch.' },
              { label: 'Legal operations', text: 'Teams managing legal workflows, document volumes, and processes where AI can bring efficiency when introduced correctly.' },
            ].map((item, i) => (
              <FadeUp key={i} delay={i * 60}>
                <div style={{ background: 'rgba(184,198,255,0.06)', border: '1px solid rgba(184,198,255,0.15)', borderRadius: '10px', padding: '24px 22px' }}>
